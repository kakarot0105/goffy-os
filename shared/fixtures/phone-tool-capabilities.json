  {
    "name": "phone.memory.list",
    "title": "List approved phone memories",
    "description": "Read bounded user-approved memories stored locally on this phone.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {},
      "type": "object"
    },
    "outputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "status": {"type": "string", "minLength": 1, "const": "available"},
        "count": {"type": "integer", "minimum": 0, "maximum": 100},
        "truncated": {"type": "boolean"},
        "entries": {
          "type": "array",
          "items": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "additionalProperties": false,
            "properties": {
              "memoryId": {"type": "integer", "minimum": 1},
              "text": {"type": "string", "minLength": 1, "maxLength": 512},
              "createdAtEpochMillis": {"type": "integer", "minimum": 1},
              "provenance": {
                "type": "string",
                "minLength": 1,
                "const": "user_approved_phone_command"
              }
            },
            "required": ["memoryId", "text", "createdAtEpochMillis", "provenance"],
            "type": "object"
          },
          "maxItems": 20
        }
      },
      "required": ["status", "count", "truncated", "entries"],
      "type": "object"
    },
    "annotations": {
      "readOnlyHint": true,
      "destructiveHint": false,
      "idempotentHint": true,
      "openWorldHint": false
    },
