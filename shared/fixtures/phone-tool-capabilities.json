  {
    "name": "phone.timer.create",
    "title": "Create system timer",
    "description": "Dispatch an approved timer to an allowlisted Android system Clock.",
    "inputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "durationSeconds": {"type": "integer", "minimum": 1, "maximum": 86400},
        "skipClockUi": {"type": "boolean", "const": true}
      },
      "required": ["durationSeconds", "skipClockUi"],
      "type": "object"
    },
    "outputSchema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "durationSeconds": {"type": "integer", "minimum": 1, "maximum": 86400},
        "clockPackage": {
          "type": "string",
          "minLength": 1,
          "enum": ["com.android.deskclock", "com.google.android.deskclock"]
        },
        "clockActivity": {"type": "string", "minLength": 1, "maxLength": 256},
        "systemApplication": {"type": "boolean", "const": true},
        "skipClockUiRequested": {"type": "boolean", "const": true},
        "systemAction": {
          "type": "string",
          "minLength": 1,
          "const": "android.intent.action.SET_TIMER"
        }
      },
      "required": [
        "durationSeconds",
        "clockPackage",
        "clockActivity",
        "systemApplication",
        "skipClockUiRequested",
        "systemAction"
      ],
      "type": "object"
    },
    "annotations": {
      "readOnlyHint": false,
      "destructiveHint": false,
      "idempotentHint": false,
      "openWorldHint": false
