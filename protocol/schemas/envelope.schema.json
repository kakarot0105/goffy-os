{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goffy.dev/protocol/0.2.0/envelope.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocolVersion",
    "messageId",
    "timestamp",
    "deviceId",
    "messageType",
    "payload"
  ],
  "properties": {
    "protocolVersion": {
      "const": "0.2.0"
    },
    "messageId": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "deviceId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "messageType": {
      "type": "string",
      "enum": [
        "PairingRequest",
        "PairingChallenge",
        "PairingResponse",
        "PairingSuccess",
        "DeviceStatus",
        "CapabilityDiscoveryRequest",
        "CapabilityDiscoveryResponse",
        "UserIntent",
        "ExecutionPlan",
        "ApprovalRequest",
        "ApprovalResponse",
        "ToolInvocation",
        "ToolProgress",
        "ToolResult",
        "ToolError",
        "VerificationResult",
        "CancellationRequest",
        "Heartbeat",
        "AuditEvent"
      ]
    },
    "payload": {
      "type": "object"
    },
    "correlationId": {
      "oneOf": [
        {
          "type": "string",
          "format": "uuid"
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
