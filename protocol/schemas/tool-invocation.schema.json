{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goffy.dev/protocol/0.2.0/tool-invocation.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "toolName",
    "arguments"
  ],
  "properties": {
    "toolName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.]*$",
      "minLength": 1,
      "maxLength": 128
    },
    "arguments": {
      "type": "object"
    }
  }
}
