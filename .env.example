# Generate a unique development value. Never commit the real token.
GOFFY_HUB_TOKEN=replace-with-a-long-random-development-token
GOFFY_HUB_HOST=127.0.0.1
GOFFY_HUB_PORT=8787
GOFFY_HUB_ALLOW_LAN=false
# Optional paired-device mode. Use an absolute path outside the repository.
# GOFFY_PAIRING_DATABASE_PATH="/Users/you/Library/Application Support/GOFFY Hub/credentials.sqlite3"
# GOFFY_PAIRING_CHALLENGE_TTL_SECONDS=120
# LAN mode additionally requires both existing TLS files.
# GOFFY_HUB_TLS_CERT_FILE=/absolute/path/to/cert.pem
# GOFFY_HUB_TLS_KEY_FILE=/absolute/path/to/key.pem
# Optional SAFE Mac app catalog. This lists approved names and bundle IDs only;
# it does not launch apps or scan /Applications.
# GOFFY_MAC_APP_ALLOWLIST=Safari=com.apple.Safari,Terminal=com.apple.Terminal
