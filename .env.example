# Generate a unique development value. Never commit the real token.
GOFFY_HUB_TOKEN=replace-with-a-long-random-development-token
GOFFY_HUB_HOST=127.0.0.1
GOFFY_HUB_PORT=8787
GOFFY_HUB_ALLOW_LAN=false
# LAN mode additionally requires both existing TLS files.
# GOFFY_HUB_TLS_CERT_FILE=/absolute/path/to/cert.pem
# GOFFY_HUB_TLS_KEY_FILE=/absolute/path/to/key.pem
